generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────────────────

enum OrgType {
  PLATFORM
  RESELLER
  CLIENT
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  orgType     OrgType  @default(CLIENT)
  parentId    String?
  logoUrl     String?
  website     String?
  vatNumber   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children    Organization[] @relation("OrgHierarchy")

  memberships     Membership[]
  customers       Customer[]
  assets          Asset[]
  assessments     Assessment[]
  agentTokens     AgentToken[]
  scanJobs        ScanJob[]
  findings        Finding[]
  reports         Report[]
  auditLogs       AuditLog[]
  contracts       ServiceContract[]
  discoveredHosts DiscoveredHost[]

  @@map("organizations")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  auditLogs    AuditLog[]
  roeApprovals RulesOfEngagement[] @relation("RoeApprovedBy")

  @@map("users")
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(PENTESTER)
  userId         String
  organizationId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("memberships")
}

enum MembershipRole {
  OWNER
  ADMIN
  PENTESTER
  VIEWER
}

// ─── SERVICE CATALOG ─────────────────────────────────────────────────────────

model ScanTypeDef {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  scanJobType   String   // valore dell'enum ScanType: NMAP_DISCOVERY, NMAP_FULL, ecc.
  defaultConfig Json     @default("{}")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceTypes  ServiceType[]

  @@map("scan_type_defs")
}

model ServiceType {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts    ServiceContract[]
  assessments  Assessment[]
  scanTypeDefs ScanTypeDef[]

  @@map("service_types")
}

model ServiceContract {
  id              String    @id @default(cuid())
  organizationId  String
  serviceTypeId   String
  maxAssessments  Int?
  maxAssets       Int?
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceType  ServiceType  @relation(fields: [serviceTypeId], references: [id])

  @@unique([organizationId, serviceTypeId])
  @@index([organizationId])
  @@map("service_contracts")
}

// ─── CUSTOMER & ASSET ────────────────────────────────────────────────────────

model Customer {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  contactEmail   String?
  contactName    String?
  phone          String?
  address        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       Asset[]
  assessments  Assessment[]

  @@index([organizationId])
  @@map("customers")
}

model Asset {
  id             String    @id @default(cuid())
  name           String
  type           AssetType
  value          String
  description    String?
  organizationId String
  customerId     String
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  scopeItems   ScopeItem[]

  @@index([organizationId])
  @@index([customerId])
  @@map("assets")
}

enum AssetType {
  IP
  CIDR
  DOMAIN
  URL
  HOST
}

// ─── ASSESSMENT ──────────────────────────────────────────────────────────────

model Assessment {
  id             String           @id @default(cuid())
  title          String
  description    String?
  type           AssessmentType
  status         AssessmentStatus @default(DRAFT)
  organizationId String
  customerId     String
  serviceTypeId  String?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer        Customer           @relation(fields: [customerId], references: [id])
  serviceType     ServiceType?       @relation(fields: [serviceTypeId], references: [id])
  scopeItems      ScopeItem[]
  roe             RulesOfEngagement?
  scanJobs        ScanJob[]
  findings        Finding[]
  reports         Report[]
  discoveredHosts DiscoveredHost[]

  @@index([organizationId])
  @@index([customerId])
  @@map("assessments")
}

enum AssessmentType {
  EXTERNAL
  INTERNAL
  WEBAPP
  RETEST
}

enum AssessmentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ScopeItem {
  id           String   @id @default(cuid())
  assessmentId String
  assetId      String
  notes        String?
  createdAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, assetId])
  @@map("scope_items")
}

// ─── RULES OF ENGAGEMENT ─────────────────────────────────────────────────────

model RulesOfEngagement {
  id              String    @id @default(cuid())
  assessmentId    String    @unique
  content         String    @db.Text
  status          RoeStatus @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  customerToken   String    @unique @default(cuid())
  customerEmail   String?
  signatureHash   String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  approvedBy User?      @relation("RoeApprovedBy", fields: [approvedById], references: [id])

  @@map("rules_of_engagement")
}

enum RoeStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

// ─── SCAN JOBS ────────────────────────────────────────────────────────────────

model ScanJob {
  id             String    @id @default(cuid())
  assessmentId   String
  organizationId String
  type           ScanType
  status         JobStatus @default(PENDING)
  config         Json
  result         Json?
  errorMessage   String?
  agentTokenId   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assessment      Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  organization    Organization     @relation(fields: [organizationId], references: [id])
  agentToken      AgentToken?      @relation(fields: [agentTokenId], references: [id])
  findings        Finding[]
  discoveredHosts DiscoveredHost[]

  @@index([organizationId])
  @@index([assessmentId])
  @@map("scan_jobs")
}

enum ScanType {
  NMAP_DISCOVERY
  NMAP_FULL
  NMAP_VULN
  NUCLEI_CVE
  NUCLEI_WEBAPP
  MANUAL
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── DISCOVERED HOSTS (risultato fase discovery) ──────────────────────────────

model DiscoveredHost {
  id             String   @id @default(cuid())
  scanJobId      String
  assessmentId   String
  organizationId String
  ipAddress      String
  hostname       String?
  osInfo         String?
  openPorts      Json
  rawOutput      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scanJob      ScanJob      @relation(fields: [scanJobId], references: [id], onDelete: Cascade)
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([scanJobId, ipAddress])
  @@index([assessmentId])
  @@map("discovered_hosts")
}

// ─── FINDINGS ────────────────────────────────────────────────────────────────

model Finding {
  id             String          @id @default(cuid())
  assessmentId   String
  scanJobId      String?
  organizationId String
  title          String
  severity       FindingSeverity
  status         FindingStatus   @default(OPEN)
  description    String          @db.Text
  evidence       String?         @db.Text
  remediation    String?         @db.Text
  affectedAsset  String
  cve            String?
  cvss           Float?
  cwe            String?
  port           Int?
  protocol       String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  scanJob      ScanJob?     @relation(fields: [scanJobId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([assessmentId])
  @@map("findings")
}

enum FindingSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum FindingStatus {
  OPEN
  CONFIRMED
  FALSE_POSITIVE
  REMEDIATED
  ACCEPTED_RISK
}

// ─── REPORTS ─────────────────────────────────────────────────────────────────

model Report {
  id             String       @id @default(cuid())
  assessmentId   String
  organizationId String
  type           ReportType
  status         ReportStatus @default(GENERATING)
  filePath       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("reports")
}

enum ReportType {
  EXECUTIVE
  TECHNICAL
  RETEST
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
}

// ─── AGENT TOKENS ────────────────────────────────────────────────────────────

model AgentToken {
  id             String      @id @default(cuid())
  name           String
  tokenHash      String      @unique
  organizationId String
  customerId     String?
  status         AgentStatus @default(ACTIVE)
  lastSeenAt     DateTime?
  lastSeenIp     String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scanJobs     ScanJob[]

  @@index([organizationId])
  @@map("agent_tokens")
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
